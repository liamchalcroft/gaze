# Copy this file to .env and fill in the values you need.

# Cloud model access. Provide one of the following.
# OpenRouter API key (used for OpenRouter-hosted models).
OPENROUTER_API_KEY=
# OpenAI API key (used for the OpenAI API and OpenAI-compatible hosts).
OPENAI_API_KEY=

# Optional: NCBI API key for higher PubMed rate limits.
NCBI_API_KEY=
# Optional: contact email for PubMed E-utilities API compliance.
NCBI_EMAIL=

# Optional: set to 1 to allow sending your API key to a non-allowlisted
# model host (for example a custom or local --base-url). Leave unset to keep
# the default host allowlist.
GAZE_ALLOW_CUSTOM_BASE_URL=
